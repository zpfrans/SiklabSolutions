{
  "name": "siklab-chatbot-backend",
  "version": "1.0.0",
  "description": "Secure backend API for Siklab Solutions ChatBot",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed-mongodb.js",
    "prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start server.js --name 'siklab-api' --instances max --exec-mode cluster",
    "pm2:stop": "pm2 stop siklab-api",
    "pm2:restart": "pm2 restart siklab-api",
    "pm2:logs": "pm2 logs siklab-api"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "morgan": "^1.10.0",
    "openai": "^4.24.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
